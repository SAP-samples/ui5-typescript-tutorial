# .npmrc — supply-chain hardening

# Explicit registry — prevents dependency confusion attacks.
registry=https://registry.npmjs.org/

# Block lifecycle scripts (preinstall/postinstall) by default.
ignore-scripts=true

# Block git dependencies.
allow-git=none

# Don't install packages published less than 7 days ago.
min-release-age=7

# Pin exact versions.
save-exact=true
